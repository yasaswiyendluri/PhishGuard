{
    "manifest_version": 3,
    "name": "PhishGuard",
    "version": "1.0.0",
    "description": "ML-powered phishing URL detection with Cyber Threat Intelligence",

    "permissions": ["activeTab", "tabs", "storage", "notifications"],

    "host_permissions": ["https://phishguard-10mf.onrender.com/*"],

    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        },
        "default_title": "PhishGuard — Click to scan this page"
    },

    "background": {
        "service_worker": "background/service_worker.js"
    },

    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}
